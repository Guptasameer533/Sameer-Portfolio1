# Contact form delivery via Resend (https://resend.com — free tier: 100 emails/day).
# Required — without this key the form returns a graceful "email me directly"
# fallback instead of actually sending. (FormSubmit was tried first since it
# needs no account, but Cloudflare blocks it when called from Vercel's
# serverless IPs with a 403 bot-challenge, so it can never work in production.)
RESEND_API_KEY=

# Where contact form messages are delivered
CONTACT_TO=guptasameer533@gmail.com
# Resend sender — keep the default until you verify a custom domain on Resend
CONTACT_FROM=Portfolio <onboarding@resend.dev>

# Set this to your deployed URL (used for SEO canonical/sitemap/OG)
NEXT_PUBLIC_SITE_URL=https://portfoliosameer.vercel.app
